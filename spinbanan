      <div class="actions" style="justify-content:flex-start;margin-top:22px;flex-wrap:wrap;gap:10px"><button class="btn go big" id="again">${r >= 5 ? 'Tag en ny runde' : 'Se om du kan få det gode tilbud'} ▸</button><button class="btn big" id="share">Del resultat ▸</button></div>
    </div>`;
  document.getElementById('again').onclick = startGame;
  const shareBtn = document.getElementById('share');
  shareBtn.onclick = ()=>{
    const text = 'Spin & Skandale: Krisemanageren\n' + r + '/10, rekrutteret af ' + rec.navn + '\n' + grid + '\nKan du slå mig?';
    if(navigator.share){
      navigator.share({title:'Spin & Skandale', text:text, url:location.href}).catch(()=>{});
    } else if(navigator.clipboard){
      navigator.clipboard.writeText(text + '\n' + location.href).then(()=>{
        shareBtn.textContent = 'Kopieret ✓';
        setTimeout(()=>{ shareBtn.textContent = 'Del resultat ▸'; }, 2000);
      }).catch(()=>{});
    }
  };
}

document.addEventListener('keydown', e=>{
  if(!state.started) return;
  const idx = SLOTS.indexOf(e.key.toUpperCase());
  if(idx >= 0){
    const btn = app.querySelector('.choice[data-slot="'+idx+'"]');
    if(btn) btn.click();
  }
});

intro();
</script>
